# ── Scout configuration ──────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env. All secrets come from here.

# Which data source the MCP server reads from.
#   demo    -> reads the locally-seeded synthetic store (no Shopify needed). EXPLICIT,
#              labeled everywhere. Use this to run the whole system today.
#   shopify -> reads the real Shopify Admin API. Fails LOUD if creds below are missing.
SCOUT_DATA_SOURCE=demo

# The single store id for v1 (multi-tenant-ready: present everywhere).
SCOUT_STORE_ID=demo-store

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for local dev; swap for a Postgres URL in prod (Alembic migrations ready).
SCOUT_DATABASE_URL=sqlite:///scout.db

# ── Shopify (only required when SCOUT_DATA_SOURCE=shopify) ────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2026-04
# Used to verify inbound webhook HMAC signatures. From the custom app's API secret.
SHOPIFY_WEBHOOK_SECRET=your_webhook_signing_secret

# ── LLM (only required when SCOUT_LLM_MODE=openai|azure|groq) ─────────────────
#   stub   -> deterministic, no network, no key. Powers the demo + eval reproducibly.
#   openai -> real OpenAI API.
#   azure  -> Azure OpenAI (swappable backend).
#   groq   -> Groq (OpenAI-compatible, fast/cheap). Set GROQ_API_KEY + a Groq model.
SCOUT_LLM_MODE=stub
SCOUT_LLM_MODEL=gpt-4.1
# OpenAI:
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# Groq (e.g. SCOUT_LLM_MODEL=llama-3.3-70b-versatile):
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx
# Optional: point the openai-compatible client at any base URL (Groq/Together/etc.)
SCOUT_LLM_BASE_URL=
# Azure-only:
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Agent governance (cost / loop caps) ──────────────────────────────────────
SCOUT_MAX_HYPOTHESES=4
SCOUT_MAX_ITERS_PER_HYPOTHESIS=3
SCOUT_RUN_TOKEN_BUDGET=20000
# Debounce: at most one investigation run per store per this many minutes.
SCOUT_DEBOUNCE_MINUTES=10

# ── Detection tuning (justified defaults; see scout/agent/detection.py) ───────
SCOUT_BASELINE_SAME_WEEKDAYS=5
SCOUT_MIN_BASELINE_HISTORY=3
SCOUT_ROBUST_Z_THRESHOLD=3.5

# ── Observability ────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=scout
LOG_LEVEL=INFO
LOG_JSON=false

# ── Notifications (optional; disabled unless enabled + configured) ────────────
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-xxxx
SLACK_CHANNEL=#scout-findings

EMAIL_ENABLED=false
SENDGRID_API_KEY=SG.xxxx
EMAIL_FROM=scout@example.com
EMAIL_TO=you@example.com
